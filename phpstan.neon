includes:
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - src
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Symfony Config: getRootNode() return type imprecision (NodeDefinition vs ArrayNodeDefinition)
        - identifier: method.notFound
          path: '*Configuration*.php'
        - identifier: method.notFound
          path: '*Configuration/*.php'
        - identifier: method.nonObject
          path: src/Runtime/Pipeline/Configuration.php
        # Action: State builder returns Stmt, withState/addAction expect Expr (API mismatch)
        - message: '~withState\(\) expects PhpParser\\Node\\Expr~'
          path: src/Action/Action.php
        - message: '~addAction\(\) expects.*PhpParser\\Node\\Expr~'
          path: src/Action/Action.php
        # API client return types: instanceof narrowing
        - identifier: instanceof.alwaysFalse
          path: src/Cloud/Pipeline.php
        - identifier: instanceof.alwaysFalse
          path: src/Cloud/Workflow.php
        # Cloud API: array_map callback types, Deferred generics, API type mismatches
        - identifier: argument.type
          path: src/Cloud/Workflow.php
        - identifier: argument.type
          path: src/Cloud/Pipeline.php
        - identifier: missingType.generics
          path: src/Cloud/CommandBus.php
        - identifier: function.impossibleType
          path: src/Cloud/Pipeline.php
        - identifier: function.impossibleType
          path: src/Cloud/Workflow.php
        - identifier: deadCode.unreachable
          path: src/Cloud/Pipeline.php
        - identifier: deadCode.unreachable
          path: src/Cloud/Workflow.php
        # Composer Configuration: closure return type inference
        - identifier: return.type
          path: src/Feature/Composer/Configuration.php
        - identifier: missingType.iterableValue
        - identifier: parameter.implicitlyNullable
        - message: '~Unable to resolve the template type T in call to function~'
        - message: '~expects PhpParser\\Node\\Expr, PhpParser\\Node given~'
        - message: '~expects string, string\|false given~'
        - message: '~does not accept array~'
        - message: '~pipe\(\) expects~'
        - message: '~IteratorAggregate but does not specify its types~'
        - message: '~has no return type specified~'
        - message: '~Binary operation.*between int\|string~'
        - message: '~expects string, string\|null given~'
        - message: '~InMemory constructor expects string, array\|string given~'
        - message: '~registerProvider\(\) expects~'
        - message: '~is unused~'
        - message: '~ReflectionAttribute but does not specify its types~'
        - identifier: property.onlyWritten
        - message: '~expects.*PipelinePluginInterface~'
        - message: '~expects.*PluginConfigurationInterface~'
        - message: '~Cannot access offset string on iterable~'
        - message: '~Node\\\\Expr~'
        - message: '~Return_ constructor~'
